# Copy to `.env` for local runs: `cp .example.env .env` then edit values.
# Run after build: `node dist/index.js`
#
# GitHub Actions maps `with:` inputs to INPUT_* (see action.yml).

# Required — success | failure | cancelled | custom
INPUT_STATUS=success

# Required — Slack incoming webhook URL (use a test channel webhook in dev)
INPUT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxxxxxxxxxxxxxxxxxxxxxxx

# Simulates the GitHub Actions environment
GITHUB_ACTOR=your-github-username
GITHUB_REPOSITORY=owner/repo-name
GITHUB_REF=refs/heads/main
GITHUB_RUN_ID=123456789
